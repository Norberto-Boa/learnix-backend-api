// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

generator cliClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// USERS AND ROLES
enum ROLE {
  SUPERADMIN
  ADMIN
  MANAGER
  CLERK
}

enum STUDENT_STATUS {
  ACTIVE
  INACTIVE
}

enum STATUS {
  ACTIVE
  SUSPENDED
}

enum GENDER {
  MALE
  FEMALE
}

enum ENROLLMENT_STATUS {
  PENDING
  ACTIVE
  TRANSFERRED
  CANCELLED
  COMPLETED
}

model School {
  id     String @id @default(uuid())
  name   String
  nuit   String @unique
  slug   String @unique
  status String

  users         User[]
  auditLogs     AuditLog[]
  academicYears AcademicYear[]
  students      Student[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  documentTypes    DocumentType[]
  studentDocuments StudentDocument[]
  grades           Grade[]
  classrooms       Classroom[]
  enrollments      enrollment[]
  feeTypes         FeeType[]
  feeStructures    FeeStructure[]
  penaltyPolicies  PenaltyPolicy[]

  @@map("schools")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     ROLE   @default(CLERK)
  status   STATUS @default(ACTIVE)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  auditLogs AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  entity   String
  entityId String?
  payload  Json

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model AcademicYear {
  id String @id @default(uuid())

  year  Int
  label String

  startDate DateTime
  endDate   DateTime

  isActive Boolean @default(false)
  isClosed Boolean @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  classrooms      Classroom[]
  enrollments     enrollment[]
  feeStructures   FeeStructure[]
  penaltyPolicies PenaltyPolicy[]

  @@unique([year, schoolId])
  @@map("academic_years")
}

model DocumentType {
  id String @id @default(uuid())

  type  String
  label String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  studentDocuments StudentDocument[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([type, schoolId])
  @@map("document_types")
}

model Student {
  id                 String         @id @default(uuid())
  name               String
  registrationNumber String
  dateOfBirth        DateTime
  gender             GENDER
  status             STUDENT_STATUS @default(ACTIVE)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  studentDocuments StudentDocument[]
  enrollments      enrollment[]

  @@unique([registrationNumber, schoolId])
  @@map("students")
}

model StudentDocument {
  id String @id @default(uuid())

  documentNumber String
  fileUrl        String?

  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([documentTypeId, documentNumber, schoolId])
  @@map("student_documents")
}

model Grade {
  id String @id @default(uuid())

  name  String
  order Int

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  classrooms      Classroom[]
  feeStructures   FeeStructure[]
  penaltyPolicies PenaltyPolicy[]

  @@unique([schoolId, name])
  @@map("grades")
}

model Classroom {
  id String @id @default(uuid())

  name     String
  capacity Int

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  enrollments enrollment[]

  @@unique([schoolId, name, gradeId, academicYearId])
  @@map("classrooms")
}

model enrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  status ENROLLMENT_STATUS @default(ACTIVE)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, studentId, academicYearId])
  @@map("enrollments")
}

enum FEE_TYPE_CATEGORY {
  NORMAL
  PENALTY
}

enum FEE_SCOPE {
  SCHOOL
  GRADE
}

model FeeType {
  id String @id @default(uuid())

  name        String
  code        String
  category    FEE_TYPE_CATEGORY @default(NORMAL)
  isRecurring Boolean           @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  feeStructures     FeeStructure[]
  penaltyFeeType    PenaltyPolicy[] @relation("PenaltyPolicy_penaltyFeeType")
  penaltyFeeTrigger PenaltyPolicy[] @relation("PenaltyPolicy_triggerFeeType")

  @@unique([schoolId, code])
  @@map("fee_types")
}

model FeeStructure {
  id String @id @default(uuid())

  feeTypeId String
  feeType   FeeType @relation(fields: [feeTypeId], references: [id])

  scope FEE_SCOPE

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  gradeId String?
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  amount Decimal @db.Decimal(10, 2)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, feeTypeId, academicYearId, gradeId])
  @@map("fee_structures")
}

enum PENALTY_MODE {
  FIXED
  PERCENTAGE
  INTERVAL_FIXED
  INTERVAL_PERCENTAGE
}

model PenaltyPolicy {
  id String @id @default(uuid())

  name String

  triggerFeeTypeId String
  triggerFeeType   FeeType @relation("PenaltyPolicy_triggerFeeType", fields: [triggerFeeTypeId], references: [id])

  penaltyFeeTypeId String
  penaltyFeeType   FeeType @relation("PenaltyPolicy_penaltyFeeType", fields: [penaltyFeeTypeId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  gradeId String?
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  mode  PENALTY_MODE
  value Decimal      @db.Decimal(10, 2)

  isActive Boolean @default(true)

  graceDay     Int
  intervalDays Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("penalty_policies")
}
