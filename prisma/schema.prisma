// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

generator cliClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// USERS AND ROLES
enum ROLE {
  SUPERADMIN
  ADMIN
  MANAGER
  CLERK
}

enum STUDENT_STATUS {
  ACTIVE
  INACTIVE
}

enum STATUS {
  ACTIVE
  SUSPENDED
}

enum GENDER {
  MALE
  FEMALE
}

enum ENROLLMENT_STATUS {
  PENDING
  ACTIVE
  TRANSFERRED
  CANCELLED
  COMPLETED
}

model School {
  id     String @id @default(uuid())
  name   String
  nuit   String @unique
  slug   String @unique
  status String

  users         User[]
  auditLogs     AuditLog[]
  academicYears AcademicYear[]
  students      Student[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  documentTypes     DocumentType[]
  studentDocuments  StudentDocument[]
  grades            Grade[]
  classrooms        Classroom[]
  enrollments       Enrollment[]
  feeTypes          FeeType[]
  feeStructures     FeeStructure[]
  penaltyPolicies   PenaltyPolicy[]
  products          Product[]
  enrollmentCharges EnrollmentCharge[]
  invoices          Invoice[]

  @@map("schools")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     ROLE   @default(CLERK)
  status   STATUS @default(ACTIVE)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  auditLogs AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("users")
}

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  entity   String
  entityId String?
  payload  Json

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model AcademicYear {
  id String @id @default(uuid())

  year  Int
  label String

  startDate DateTime
  endDate   DateTime

  isActive Boolean @default(false)
  isClosed Boolean @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  classrooms        Classroom[]
  enrollments       Enrollment[]
  feeStructures     FeeStructure[]
  penaltyPolicies   PenaltyPolicy[]
  enrollmentCharges EnrollmentCharge[]

  @@unique([year, schoolId])
  @@map("academic_years")
}

model DocumentType {
  id String @id @default(uuid())

  type  String
  label String

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  studentDocuments StudentDocument[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([type, schoolId])
  @@map("document_types")
}

model Student {
  id                 String         @id @default(uuid())
  name               String
  registrationNumber String
  dateOfBirth        DateTime
  gender             GENDER
  status             STUDENT_STATUS @default(ACTIVE)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  studentDocuments StudentDocument[]
  enrollments      Enrollment[]
  invoices         Invoice[]

  @@unique([registrationNumber, schoolId])
  @@map("students")
}

model StudentDocument {
  id String @id @default(uuid())

  documentNumber String
  fileUrl        String?

  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([documentTypeId, documentNumber, schoolId])
  @@map("student_documents")
}

model Grade {
  id String @id @default(uuid())

  name  String
  order Int

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  classrooms      Classroom[]
  feeStructures   FeeStructure[]
  penaltyPolicies PenaltyPolicy[]

  @@unique([schoolId, name])
  @@map("grades")
}

model Classroom {
  id String @id @default(uuid())

  name     String
  capacity Int

  gradeId String
  grade   Grade  @relation(fields: [gradeId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  enrollments Enrollment[]

  @@unique([schoolId, name, gradeId, academicYearId])
  @@map("classrooms")
}

model Enrollment {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  status ENROLLMENT_STATUS @default(ACTIVE)

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  enrollmentCharges EnrollmentCharge[]
  invoices          Invoice[]

  @@unique([schoolId, studentId, academicYearId])
  @@map("enrollments")
}

enum FEE_TYPE_CATEGORY {
  NORMAL
  PENALTY
}

enum FEE_SCOPE {
  SCHOOL
  GRADE
}

model FeeType {
  id String @id @default(uuid())

  name        String
  code        String
  category    FEE_TYPE_CATEGORY @default(NORMAL)
  isRecurring Boolean           @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  feeStructures     FeeStructure[]
  penaltyFeeType    PenaltyPolicy[]    @relation("PenaltyPolicy_penaltyFeeType")
  penaltyFeeTrigger PenaltyPolicy[]    @relation("PenaltyPolicy_triggerFeeType")
  enrollmentCharges EnrollmentCharge[]

  @@unique([schoolId, code])
  @@map("fee_types")
}

model FeeStructure {
  id String @id @default(uuid())

  feeTypeId String
  feeType   FeeType @relation(fields: [feeTypeId], references: [id])

  scope FEE_SCOPE

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  gradeId String?
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  amount Decimal @db.Decimal(10, 2)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, feeTypeId, academicYearId, gradeId])
  @@map("fee_structures")
}

enum PENALTY_MODE {
  FIXED
  PERCENTAGE
  INTERVAL_FIXED
  INTERVAL_PERCENTAGE
}

model PenaltyPolicy {
  id String @id @default(uuid())

  name String

  triggerFeeTypeId String
  triggerFeeType   FeeType @relation("PenaltyPolicy_triggerFeeType", fields: [triggerFeeTypeId], references: [id])

  penaltyFeeTypeId String
  penaltyFeeType   FeeType @relation("PenaltyPolicy_penaltyFeeType", fields: [penaltyFeeTypeId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  gradeId String?
  grade   Grade?  @relation(fields: [gradeId], references: [id])

  mode  PENALTY_MODE
  value Decimal      @db.Decimal(10, 2)

  isActive Boolean @default(true)

  graceDay     Int
  intervalDays Int?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@map("penalty_policies")
}

model Product {
  id String @id @default(uuid())

  name  String
  code  String
  price Decimal @db.Decimal(10, 2)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  invoiceItems InvoiceItem[]

  @@unique([schoolId, name])
  @@map("products")
}

enum CHARGE_STATUS {
  PENDING
  INVOICED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model EnrollmentCharge {
  id String @id @default(uuid())

  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])

  feeTypeId String
  feeType   FeeType @relation(fields: [feeTypeId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  referenceYear  Int
  referenceMonth Int

  dueDate DateTime

  baseAmount Decimal @db.Decimal(10, 2)

  penaltyAmount Decimal @default(0) @db.Decimal(10, 2)

  totalAmount Decimal @db.Decimal(10, 2)

  paidAmount Decimal @default(0) @db.Decimal(10, 2)

  balanceAmount Decimal @db.Decimal(10, 2)

  status CHARGE_STATUS @default(PENDING)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  invoiceItems InvoiceItem[]

  @@unique([id, schoolId])
  @@unique([enrollmentId, feeTypeId, referenceYear, referenceMonth])
  @@index([schoolId, academicYearId, status])
  @@index([schoolId, referenceYear, referenceMonth])
  @@map("enrollment_charges")
}

enum INVOICE_STATUS {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum INVOICE_ITEM_TYPE {
  ENROLLMENT_CHARGE
  PRODUCT
  MANUAL
  CREDIT_APPLICATION
}

model Invoice {
  id String @id @default(uuid())

  invoiceNumber String

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])
  enrollmentId String?

  totalAmount   Decimal @db.Decimal(10, 2)
  paidAmount    Decimal @default(0) @db.Decimal(10, 2)
  balanceAmount Decimal @db.Decimal(10, 2)

  issuedAt DateTime @default(now())
  dueDate  DateTime

  status INVOICE_STATUS @default(PENDING)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  items InvoiceItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([schoolId, invoiceNumber])
  @@index([schoolId, studentId, status])
  @@map("invoices")
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  type INVOICE_ITEM_TYPE

  enrollmentChargeId String?
  enrolllmentCharge  EnrollmentCharge? @relation(fields: [enrollmentChargeId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  description String
  unitAmount  Decimal @db.Decimal(10, 2)
  quantity    Int     @default(1)
  totalAmount Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index(enrollmentChargeId)
  @@index(productId)
  @@map("invoice_items")
}
